{
  "name": "gpt-voyager-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "icons:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-icons.ps1",
    "webstore:assets": "powershell -ExecutionPolicy Bypass -File scripts/generate-webstore-assets.ps1",
    "package:zip": "powershell -ExecutionPolicy Bypass -File scripts/package-release.ps1"
  },
  "dependencies": {
    "mermaid": "^11.12.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "turndown": "^7.2.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.24",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@types/turndown": "^5.0.5",
    "esbuild": "^0.25.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  }
}
